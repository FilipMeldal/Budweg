<Window x:Class="Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dashboard"
        xmlns:viewmodels="clr-namespace:Dashboard.ViewModels"
        xmlns:views="clr-namespace:Dashboard.Views"
        xmlns:models="clr-namespace:Dashboard.Models"
        mc:Ignorable="d"
        Title="Budweg Dashboard" Height="600" Width="800" MinWidth="700" MinHeight="500"
        WindowState="Maximized">
    <Grid>
        <ContentControl Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type viewmodels:DashBoardViewModel}">
                    <views:DashBoardView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
        