<UserControl x:Class="Dashboard.Views.DashBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Dashboard.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <!--Vi bruger Styles her til at lave rounded corners på knappen, inde i stylen laver vi en border, som endligt får rounded corner men bliver sat på knappen-->
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>


    <!--Her definere alle grids så vi kan smide vores ting in rows, så det kan sættes pænt op-->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!--Header-->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Images/Budweg_Logo.png"
            HorizontalAlignment="Left" 
            Height="50"/>
        </Grid>

        <!--Her definere vi de 2 første Grid Columns-->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" CornerRadius="4" Background="White">
                <Grid Grid.Column="0" Margin="10,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Background="White" Cursor="Hand"/>
                    <ComboBox Grid.Column="1" Width="120" Grid.RowSpan="1" VerticalAlignment="Stretch" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="0" Text="☁️ CO₂ Emission" FontSize="18" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>

                    <DataGrid Name="CO2" ItemsSource="{Binding}" Grid.Row="1" Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Emission" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid Name="CO2_Inspection" ItemsSource="{Binding}" Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Milestone" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="MilestoneReached" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Inspector" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Border>

            <Border Grid.Column="1" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" CornerRadius="4" Background="White">
                <Grid Grid.Column="1" Margin="10,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Background="White" Cursor="Hand"/>
                    <ComboBox Grid.Column="1" Width="120" Grid.RowSpan="1" VerticalAlignment="Stretch" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="0" Text="⚡Energy Consumption" FontSize="18" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>

                    <DataGrid Name="Energy" ItemsSource="{Binding}" Grid.Row="1" Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Watt" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid Name="Energy_Inspection" ItemsSource="{Binding}" Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Milestone" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="MilestoneReached" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Inspector" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!--Her bliver de 2 næste rows oprettet så vi kan smide info ind i dem-->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" CornerRadius="4" Background="White">
                <Grid Grid.Column="0" Margin="10,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Background="White" Cursor="Hand"/>
                    <ComboBox Grid.Column="1" Width="120" Grid.RowSpan="1" VerticalAlignment="Stretch" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="0" Text="🗑️ Waste" FontSize="18" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>

                    <DataGrid Name="Waste" ItemsSource="{Binding}" Grid.Row="1" Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="WasteAmount" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Material" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid Name="Waste_Inspection" ItemsSource="{Binding}" Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Milestone" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="MilestoneReached" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Inspector" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" CornerRadius="4" Background="White">
                <Grid Grid.Column="1" Margin="10,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Background="White" Cursor="Hand"/>
                    <ComboBox Grid.Column="1" Width="120" Grid.RowSpan="1" VerticalAlignment="Stretch" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="0" Text="🔧 BrakeCaliper" FontSize="18" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>

                    <DataGrid Name="Inspection" ItemsSource="{Binding}" Grid.Row="1" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Weight" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="RawMaterial" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Component" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid Name="BrakeCaliper_Inspection" ItemsSource="{Binding}" Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" BorderBrush="Black" BorderThickness="1" Height="auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Milestone" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="MilestoneReached" Width="*" Binding="{Binding}"></DataGridTextColumn>
                            <DataGridTextColumn Header="Inspector" Width="*" Binding="{Binding}"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!--Det sidste grid bliver brugt til at sætte knappen i-->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Create Inspection"
                    Height="75"
                    Width="150"
                    Margin="0,25,0,0"
                    Cursor="Hand"
                    Background="DarkGreen"
                    Foreground="White"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Command="{Binding CreateInspectionCommand}">
            </Button>
        </Grid>
    </Grid>
</UserControl>
